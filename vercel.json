{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install --include=optional",
  "framework": "nextjs",
  "regions": ["iad1"],
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 60
    },
    "app/api/**/*.js": {
      "maxDuration": 60
    },
    "app/api/courses/import/moodle/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/sonisweb-sync/route.ts": {
      "maxDuration": 300
    },
    "app/api/sonisweb/import/xml/route.ts": {
      "maxDuration": 300
    },
    "app/api/admin/users/bulk-delete/route.ts": {
      "maxDuration": 300
    },
    "app/api/courses/restore/route.ts": {
      "maxDuration": 300
    },
    "app/api/reports/generate/route.ts": {
      "maxDuration": 300
    },
    "app/api/reports/custom/[id]/execute/route.ts": {
      "maxDuration": 300
    },
    "app/api/analytics/export/route.ts": {
      "maxDuration": 300
    },
    "app/api/crm/campaigns/[id]/send/route.ts": {
      "maxDuration": 300
    },
    "app/api/plagiarism/check/route.ts": {
      "maxDuration": 300
    },
    "app/api/certificates/generate/route.ts": {
      "maxDuration": 300
    },
    "app/api/admin/users/[id]/progress/export/route.ts": {
      "maxDuration": 300
    },
    "app/api/admin/tenants/[id]/export/route.ts": {
      "maxDuration": 300
    },
    "app/api/admin/users/report/route.ts": {
      "maxDuration": 300
    },
    "app/api/surveys/[id]/analytics/export/route.ts": {
      "maxDuration": 300
    },
    "app/api/courses/[id]/gradebook/export/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/sonisweb-sync",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/crm-lifecycle",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/crm-engagement",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/assignment-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/email-digests",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/check-completions",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/crm-workflows",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/crm-campaigns",
      "schedule": "*/15 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ]
}

