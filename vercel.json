{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install --include=optional",
  "framework": "nextjs",
  "regions": ["iad1"],
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 60
    },
    "app/api/**/*.js": {
      "maxDuration": 60
    },
    "app/api/courses/import/moodle/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/sonisweb-sync/route.ts": {
      "maxDuration": 300
    },
    "app/api/sonisweb/import/xml/route.ts": {
      "maxDuration": 300
    },
    "app/api/admin/users/bulk-delete/route.ts": {
      "maxDuration": 300
    },
    "app/api/courses/restore/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/sonisweb-sync",
      "schedule": "0 2 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ]
}

